# Ortam değişkenleri — yalnızca İSİMLER. Gerçek değerleri .env içine yaz, ASLA commit'leme.

# Site
PUBLIC_SITE_URL=

# Analytics (Faz 3 — sağlayıcı TBD)
PUBLIC_ANALYTICS_ID=

# Google AdSense (Faz 3 — onay sonrası aktive edilir)
PUBLIC_ADSENSE_CLIENT=

# Bülten sağlayıcısı (Faz 3 — sağlayıcı TBD)
NEWSLETTER_API_KEY=
NEWSLETTER_LIST_ID=

# Trend keşif ajanı (Faz 2) — harici kaynak anahtarları
# (Çoğu kaynak anahtarsız RSS/public API; gerekirse buraya eklenir)
PRODUCTHUNT_API_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
