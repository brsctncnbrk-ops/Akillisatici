# Ortam değişkenleri — yalnızca İSİMLER. Gerçek değerleri .env içine yaz, ASLA commit'leme.

# Site
PUBLIC_SITE_URL=

# Analytics (Faz 3 — sağlayıcı TBD)
PUBLIC_ANALYTICS_ID=

# Reklam slotları yalnızca bu değer 'true' iken render edilir (ör. AdSense onayı sonrası).
PUBLIC_ADS_ENABLED=

# Google AdSense (Faz 3 — onay sonrası aktive edilir)
PUBLIC_ADSENSE_CLIENT=

# Bülten sağlayıcısı — Kit (ConvertKit), ücretsiz katman.
# Statik site olduğumuz için form doğrudan Kit'in genel embed uç noktasına POST eder;
# bu değerler GİZLİ DEĞİLDİR (form herkese açık), API anahtarı GEREKMEZ.
# Kit panelinde: Grow → Landing Pages & Forms → form oluştur → Embed → HTML.
# Aşağıdakilerden BİRİNİ doldurmak yeterli:
#   - Sadece form ID (action otomatik kurulur: https://app.kit.com/forms/<ID>/subscriptions)
PUBLIC_KIT_FORM_ID=
#   - veya Kit'in verdiği tam action URL'i (form ID'yi geçersiz kılar)
PUBLIC_KIT_FORM_ACTION=
# Not: Kit form ayarlarında "double opt-in" (çift onay) AÇIK tutun (KVKK/GDPR).
# Boş bırakılırsa bülten formu otomatik olarak "yakında" (devre dışı) görünür.

# Trend keşif ajanı (Faz 2)
# Taslak üretimi için Claude API anahtarı (GitHub repo secret olarak da tanımlanır).
ANTHROPIC_API_KEY=
# Opsiyonel: model (varsayılan claude-opus-4-8) ve üretilecek taslak sayısı (varsayılan 2).
ANTHROPIC_MODEL=
DRAFT_COUNT=
# (Çoğu trend kaynağı anahtarsız RSS; gerekirse ek kaynak anahtarları buraya)
PRODUCTHUNT_API_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
