# Ortam değişkenleri — yalnızca İSİMLER. Gerçek değerleri .env içine yaz, ASLA commit'leme.

# Site
PUBLIC_SITE_URL=

# Analytics (Faz 3 — sağlayıcı TBD)
PUBLIC_ANALYTICS_ID=

# Reklam slotları yalnızca bu değer 'true' iken render edilir (ör. AdSense onayı sonrası).
PUBLIC_ADS_ENABLED=

# Google AdSense (Faz 3 — onay sonrası aktive edilir)
PUBLIC_ADSENSE_CLIENT=

# Bülten kayıt uç noktası — Google Apps Script web app URL'i (çift onaylı kayıt).
# Boş bırakılırsa form sitede "yakında" durumunda pasif kalır. İstemciye gömülür (gizli değil).
PUBLIC_NEWSLETTER_ENDPOINT=

# Bülten gönderim sağlayıcısı (ileride toplu gönderim için — sağlayıcı TBD)
NEWSLETTER_API_KEY=
NEWSLETTER_LIST_ID=

# Trend keşif ajanı (Faz 2)
# Taslak üretimi için Claude API anahtarı (GitHub repo secret olarak da tanımlanır).
ANTHROPIC_API_KEY=
# Opsiyonel: model (varsayılan claude-opus-4-8) ve üretilecek taslak sayısı (varsayılan 2).
ANTHROPIC_MODEL=
DRAFT_COUNT=
# (Çoğu trend kaynağı anahtarsız RSS; gerekirse ek kaynak anahtarları buraya)
PRODUCTHUNT_API_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Telegram bot — taslak onayı + günlük trafik raporu (AYNI bot kullanılır).
# GitHub repo secret olarak da tanımlanır.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Webhook güvenlik token'ı (Vercel onay fonksiyonu için).
TELEGRAM_WEBHOOK_SECRET=

# Günlük trafik raporu (GA4 Data API).
# GA4_PROPERTY_ID: GA4 mülk numarası (Admin → Property Settings → "Property ID").
# GA_SERVICE_ACCOUNT_JSON: GA mülküne "Görüntüleyici" yetkisiyle eklenmiş Google
#   service account anahtarının TAM JSON içeriği (tek satır secret olarak yapıştırılır).
GA4_PROPERTY_ID=
GA_SERVICE_ACCOUNT_JSON=
