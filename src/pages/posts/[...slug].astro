---
import { type CollectionEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
import PostCard from '../../components/PostCard.astro';
import PostCover from '../../components/PostCover.astro';
import ToolLink from '../../components/ToolLink.astro';
import { slugByKategori } from '../../lib/categories';
import { getYayindaPosts, getTools } from '../../lib/content';
import { getAuthorByName } from '../../data/authors';
import { MARKA_ADI, VARSAYILAN_OG_GORSEL } from '../../data/site';

export async function getStaticPaths() {
  // Yalnızca yayında olan yazılar için sayfa üretilir (editöryel kapı).
  const posts = await getYayindaPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const data = post.data;

const kategoriSlug = slugByKategori(data.kategori);

// Yazar bilgisi tek kaynaktan (Hakkında ile tutarlı).
const yazar = getAuthorByName(data.yazar);

// İlgili yazılar: aynı kategoriden, mevcut yazı hariç en fazla 2.
const tumPosts = await getYayindaPosts();
const ilgili = tumPosts
  .filter((p) => p.data.kategori === data.kategori && p.id !== post.id)
  .slice(0, 2);

// İncelenen araçları dizinden çöz (çapraz linkleme + affiliate görünürlüğü).
// Eşleşmeyen id'ler (henüz dizine eklenmemiş) sessizce atlanır.
const tumTools = await getTools();
const ilgiliAraclar = data.incelenenAraclar
  .map((id) => tumTools.find((t) => t.id === id))
  .filter((t): t is (typeof tumTools)[number] => Boolean(t));

const site = Astro.site?.href.replace(/\/$/, '') ?? '';
const canonical = `${site}/posts/${post.id}/`;

// Kapak/OG görseli: frontmatter'da elle verilmişse o, yoksa otomatik üretilen kart.
const kapakUrl = data.kapakGorsel ?? `/og/${post.id}.png`;

// JSON-LD: Article + BreadcrumbList (yazar Person'ı authors tek kaynağıyla birebir tutarlı).
const articleLd = {
  '@type': 'Article',
  headline: data.baslik,
  description: data.seoAciklama ?? data.ozet,
  image: `${site}${kapakUrl}`,
  datePublished: data.tarih.toISOString(),
  dateModified: (data.guncellenme ?? data.tarih).toISOString(),
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  author: {
    '@type': 'Person',
    name: yazar.name,
    jobTitle: yazar.rol,
    url: `${site}${yazar.hakkindaYolu}`,
  },
  publisher: {
    '@type': 'Organization',
    name: MARKA_ADI,
    url: site || undefined,
    logo: {
      '@type': 'ImageObject',
      url: `${site}${VARSAYILAN_OG_GORSEL}`,
      width: 1200,
      height: 630,
    },
  },
  keywords: data.anahtarKelime,
};

const breadcrumbLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Ana sayfa', item: `${site}/` },
    ...(kategoriSlug
      ? [
          {
            '@type': 'ListItem',
            position: 2,
            name: data.kategori,
            item: `${site}/kategori/${kategoriSlug}/`,
          },
        ]
      : []),
    { '@type': 'ListItem', position: kategoriSlug ? 3 : 2, name: data.baslik, item: canonical },
  ],
};

// FAQPage: yalnızca yazıda SSS tanımlıysa eklenir (sesli arama + AI cevap motoru hedefleme).
const faqLd =
  data.sss.length > 0
    ? {
        '@type': 'FAQPage',
        mainEntity: data.sss.map((s) => ({
          '@type': 'Question',
          name: s.soru,
          acceptedAnswer: { '@type': 'Answer', text: s.cevap },
        })),
      }
    : null;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [articleLd, breadcrumbLd, ...(faqLd ? [faqLd] : [])],
};
---

<BaseLayout
  title={data.seoBaslik ?? data.baslik}
  description={data.seoAciklama ?? data.ozet}
  image={kapakUrl}
  imageAlt={data.baslik}
  article={true}
  articleMeta={{
    publishedTime: data.tarih.toISOString(),
    modifiedTime: (data.guncellenme ?? data.tarih).toISOString(),
    author: yazar.name,
    section: data.kategori,
    tags: data.anahtarKelime
      ?.split(',')
      .map((k) => k.trim())
      .filter(Boolean),
  }}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-3xl">
    <nav class="mb-4 flex items-center gap-1.5 text-xs text-slate-400" aria-label="Breadcrumb">
      <a class="transition hover:text-brand" href="/">Ana sayfa</a>
      <span aria-hidden="true">/</span>
      {
        kategoriSlug && (
          <>
            <a class="transition hover:text-brand" href={`/kategori/${kategoriSlug}/`}>
              {data.kategori}
            </a>
            <span aria-hidden="true">/</span>
          </>
        )
      }
    </nav>

    <PostCover kategori={data.kategori} class="mb-8 aspect-[16/6] rounded-2xl" />

    <header class="mb-8">
      {
        kategoriSlug && (
          <a
            class="inline-flex rounded-full bg-brand/10 px-3 py-1 text-xs font-semibold text-brand-dark transition hover:bg-brand/20"
            href={`/kategori/${kategoriSlug}/`}
          >
            {data.kategori}
          </a>
        )
      }
      <h1 class="mt-3 font-display text-3xl font-extrabold leading-tight tracking-tight text-ink sm:text-4xl">
        {data.baslik}
      </h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">{data.ozet}</p>
      <div class="mt-5 flex flex-wrap items-center gap-2 border-t border-slate-100 pt-4 text-sm text-slate-500">
        <span class="font-medium text-slate-700">{yazar.name}</span>
        <span aria-hidden="true">·</span>
        <time datetime={data.tarih.toISOString()}>
          {data.tarih.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
        {
          data.guncellenme && (
            <>
              <span aria-hidden="true">·</span>
              <span>Güncellendi: {data.guncellenme.toLocaleDateString('tr-TR')}</span>
            </>
          )
        }
      </div>
    </header>

    <div class="icerik">
      <Content />
    </div>

    {
      data.sss.length > 0 && (
        <section class="mt-12" aria-labelledby="sss-baslik">
          <h2 id="sss-baslik" class="font-display text-2xl font-extrabold tracking-tight text-ink">
            Sık sorulan sorular
          </h2>
          <div class="mt-4 divide-y divide-slate-200 rounded-2xl border border-slate-200">
            {data.sss.map((s) => (
              <details class="group p-5 [&_summary::-webkit-details-marker]:hidden">
                <summary class="flex cursor-pointer items-center justify-between gap-3 font-semibold text-ink">
                  {s.soru}
                  <span
                    class="shrink-0 text-brand transition group-open:rotate-45"
                    aria-hidden="true"
                  >
                    +
                  </span>
                </summary>
                <p class="mt-3 text-sm leading-7 text-slate-600">{s.cevap}</p>
              </details>
            ))}
          </div>
        </section>
      )
    }

    <AdSlot slot="yazi-alti" />

    <footer class="mt-12 flex gap-4 rounded-2xl border border-slate-200 bg-slate-50 p-6">
      <div
        class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-brand/10 font-display text-lg font-bold text-brand-dark"
        aria-hidden="true"
      >
        {yazar.name.charAt(0)}
      </div>
      <div>
        <p class="font-display font-bold text-ink">{yazar.name}</p>
        <p class="text-xs text-slate-500">{yazar.rol}</p>
        <p class="mt-2 text-sm leading-6 text-slate-600">{yazar.kisaBio}</p>
        <a
          class="mt-2 inline-flex items-center gap-1 text-sm font-semibold text-brand-dark transition hover:gap-2"
          href={yazar.hakkindaYolu}
        >
          Yazar hakkında <span aria-hidden="true">→</span>
        </a>
      </div>
    </footer>
  </article>

  {
    ilgiliAraclar.length > 0 && (
      <section class="mx-auto mt-14 max-w-3xl">
        <h2 class="mb-4 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-slate-500">
          <span class="h-1.5 w-1.5 rounded-full bg-brand" /> Bu yazıda incelenen araçlar
        </h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {ilgiliAraclar.map((tool) => (
            <article class="card flex flex-col justify-between p-5">
              <div>
                <div class="flex items-start justify-between gap-3">
                  <h3 class="text-lg font-bold tracking-tight text-ink">{tool.data.ad}</h3>
                  {tool.data.fiyat && (
                    <span class="shrink-0 rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700">
                      {tool.data.fiyat}
                    </span>
                  )}
                </div>
                {tool.data.aciklama && (
                  <p class="mt-2 text-sm leading-6 text-slate-600">{tool.data.aciklama}</p>
                )}
              </div>
              <div class="mt-4 border-t border-slate-100 pt-3">
                <ToolLink
                  officialUrl={tool.data.officialUrl}
                  affiliateUrl={tool.data.affiliateUrl}
                  label={`${tool.data.ad}’i incele`}
                />
              </div>
            </article>
          ))}
        </div>
      </section>
    )
  }

  {
    ilgili.length > 0 && (
      <section class="mx-auto mt-14 max-w-3xl">
        <h2 class="mb-4 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-slate-500">
          <span class="h-1.5 w-1.5 rounded-full bg-brand" /> İlgili yazılar
        </h2>
        <div class="grid gap-5 sm:grid-cols-2">
          {ilgili.map((p) => (
            <PostCard post={p} />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
