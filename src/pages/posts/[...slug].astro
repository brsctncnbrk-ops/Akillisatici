---
import { type CollectionEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
import PostCard from '../../components/PostCard.astro';
import { slugByKategori } from '../../lib/categories';
import { getYayindaPosts } from '../../lib/content';
import { getAuthorByName } from '../../data/authors';
import { MARKA_ADI, VARSAYILAN_OG_GORSEL } from '../../data/site';

export async function getStaticPaths() {
  // Yalnızca yayında olan yazılar için sayfa üretilir (editöryel kapı).
  const posts = await getYayindaPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const data = post.data;

const kategoriSlug = slugByKategori(data.kategori);

// Yazar bilgisi tek kaynaktan (Hakkında ile tutarlı).
const yazar = getAuthorByName(data.yazar);

// İlgili yazılar: aynı kategoriden, mevcut yazı hariç en fazla 2.
const tumPosts = await getYayindaPosts();
const ilgili = tumPosts
  .filter((p) => p.data.kategori === data.kategori && p.id !== post.id)
  .slice(0, 2);

const site = Astro.site?.href.replace(/\/$/, '') ?? '';
const canonical = `${site}/posts/${post.id}/`;

// JSON-LD: Article + BreadcrumbList (yazar Person'ı authors tek kaynağıyla birebir tutarlı).
const articleLd = {
  '@type': 'Article',
  headline: data.baslik,
  description: data.seoAciklama ?? data.ozet,
  image: `${site}${data.kapakGorsel ?? VARSAYILAN_OG_GORSEL}`,
  datePublished: data.tarih.toISOString(),
  dateModified: (data.guncellenme ?? data.tarih).toISOString(),
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  author: {
    '@type': 'Person',
    name: yazar.name,
    jobTitle: yazar.rol,
    url: `${site}${yazar.hakkindaYolu}`,
  },
  publisher: {
    '@type': 'Organization',
    name: MARKA_ADI,
    url: site || undefined,
  },
  keywords: data.anahtarKelime,
};

const breadcrumbLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Ana sayfa', item: `${site}/` },
    ...(kategoriSlug
      ? [
          {
            '@type': 'ListItem',
            position: 2,
            name: data.kategori,
            item: `${site}/kategori/${kategoriSlug}/`,
          },
        ]
      : []),
    { '@type': 'ListItem', position: kategoriSlug ? 3 : 2, name: data.baslik, item: canonical },
  ],
};

const jsonLd = { '@context': 'https://schema.org', '@graph': [articleLd, breadcrumbLd] };
---

<BaseLayout
  title={data.seoBaslik ?? data.baslik}
  description={data.seoAciklama ?? data.ozet}
  image={data.kapakGorsel}
  article={true}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-3xl">
    <nav class="mb-4 flex items-center gap-1.5 text-xs text-slate-400" aria-label="Breadcrumb">
      <a class="transition hover:text-brand" href="/">Ana sayfa</a>
      <span aria-hidden="true">/</span>
      {
        kategoriSlug && (
          <>
            <a class="transition hover:text-brand" href={`/kategori/${kategoriSlug}/`}>
              {data.kategori}
            </a>
            <span aria-hidden="true">/</span>
          </>
        )
      }
    </nav>

    <header class="mb-8">
      {
        kategoriSlug && (
          <a
            class="inline-flex rounded-full bg-brand/10 px-3 py-1 text-xs font-semibold text-brand-dark transition hover:bg-brand/20"
            href={`/kategori/${kategoriSlug}/`}
          >
            {data.kategori}
          </a>
        )
      }
      <h1 class="mt-3 font-display text-3xl font-extrabold leading-tight tracking-tight text-ink sm:text-4xl">
        {data.baslik}
      </h1>
      <p class="mt-4 text-lg leading-8 text-slate-600">{data.ozet}</p>
      <div class="mt-5 flex flex-wrap items-center gap-2 border-t border-slate-100 pt-4 text-sm text-slate-500">
        <span class="font-medium text-slate-700">{yazar.name}</span>
        <span aria-hidden="true">·</span>
        <time datetime={data.tarih.toISOString()}>
          {data.tarih.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
        {
          data.guncellenme && (
            <>
              <span aria-hidden="true">·</span>
              <span>Güncellendi: {data.guncellenme.toLocaleDateString('tr-TR')}</span>
            </>
          )
        }
      </div>
    </header>

    <div class="icerik">
      <Content />
    </div>

    <AdSlot slot="yazi-alti" />

    <footer class="mt-12 flex gap-4 rounded-2xl border border-slate-200 bg-slate-50 p-6">
      <div
        class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-brand/10 font-display text-lg font-bold text-brand-dark"
        aria-hidden="true"
      >
        {yazar.name.charAt(0)}
      </div>
      <div>
        <p class="font-display font-bold text-ink">{yazar.name}</p>
        <p class="text-xs text-slate-500">{yazar.rol}</p>
        <p class="mt-2 text-sm leading-6 text-slate-600">{yazar.kisaBio}</p>
        <a
          class="mt-2 inline-flex items-center gap-1 text-sm font-semibold text-brand-dark transition hover:gap-2"
          href={yazar.hakkindaYolu}
        >
          Yazar hakkında <span aria-hidden="true">→</span>
        </a>
      </div>
    </footer>
  </article>

  {
    ilgili.length > 0 && (
      <section class="mx-auto mt-14 max-w-3xl">
        <h2 class="mb-4 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-slate-500">
          <span class="h-1.5 w-1.5 rounded-full bg-brand" /> İlgili yazılar
        </h2>
        <div class="grid gap-5 sm:grid-cols-2">
          {ilgili.map((p) => (
            <PostCard post={p} />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
