---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { MARKA_ADI } from '../data/site';

// Ücretsiz kaynaklar (lead magnet) hub'ı. Yeni kaynaklar buraya eklenir.
const kaynaklar = [
  {
    baslik: 'AI Araç Seçim Kontrol Listesi',
    aciklama:
      'Yanlış araca para ve zaman harcamadan önce doldurulacak 6 adımlık karar çerçevesi. Yazdır veya PDF kaydet.',
    yol: '/kaynaklar/ai-arac-secim-kontrol-listesi/',
    etiket: 'Kontrol listesi',
  },
];
---

<BaseLayout
  title={`Ücretsiz Kaynaklar — ${MARKA_ADI}`}
  description="Online satıcılar için ücretsiz, indirilebilir kaynaklar: AI aracı seçim kontrol listeleri ve pratik rehberler."
>
  <header class="mb-8 max-w-2xl">
    <h1 class="font-display text-3xl font-extrabold tracking-tight text-ink sm:text-4xl">
      Ücretsiz kaynaklar
    </h1>
    <p class="mt-3 text-lg leading-8 text-slate-600">
      Online satıcılar için hazırladığımız pratik, indirilebilir kaynaklar. Hepsi ücretsiz; doğrudan
      kullanmaya başlayabilirsin.
    </p>
  </header>

  <div class="grid gap-5 sm:grid-cols-2">
    {
      kaynaklar.map((k) => (
        <a href={k.yol} class="card flex flex-col justify-between p-6 transition hover:border-brand/40">
          <div>
            <span class="inline-flex rounded-full bg-brand/10 px-3 py-1 text-xs font-semibold text-brand-dark">
              {k.etiket}
            </span>
            <h2 class="mt-3 text-xl font-bold tracking-tight text-ink">{k.baslik}</h2>
            <p class="mt-2 text-sm leading-6 text-slate-600">{k.aciklama}</p>
          </div>
          <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-dark">
            Aç <span aria-hidden="true">→</span>
          </span>
        </a>
      ))
    }
  </div>

  <NewsletterSignup
    baslik="Ücretsiz: AI Araç Seçim Kontrol Listesi"
    aciklama="Bültene katıl; seçim kontrol listesine hemen eriş ve yeni AI araç incelemeleri e-postana gelsin."
    cta="Katıl ve eriş"
    leadMagnetUrl="/kaynaklar/ai-arac-secim-kontrol-listesi/"
    leadMagnetLabel="Kontrol listesini aç"
    source="lead-magnet-hub"
  />
</BaseLayout>
