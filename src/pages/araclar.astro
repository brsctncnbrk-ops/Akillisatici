---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import { KATEGORILER } from '../lib/categories';
import { getTools } from '../lib/content';

const tools = await getTools();

// ItemList şeması; her araç için Product (fiyat serbest metin/null olduğundan offer EKLENMEZ).
const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Online satıcılar için AI araçları',
  itemListElement: tools.map((tool, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: tool.data.ad,
      category: tool.data.kategori,
      ...(tool.data.aciklama ? { description: tool.data.aciklama } : {}),
      ...(tool.data.officialUrl ? { url: tool.data.officialUrl } : {}),
    },
  })),
};
---

<BaseLayout
  title="AI Araçları Dizini — Online satıcılar için"
  description="Online satıcılar için yapay zeka araçlarının filtrelenebilir dizini: kategori, fiyat, artılar ve eksiler."
  jsonLd={itemListLd}
>
  <header class="mb-8 max-w-2xl">
    <h1 class="font-display text-3xl font-extrabold tracking-tight text-ink sm:text-4xl">
      AI Araçları Dizini
    </h1>
    <p class="mt-3 text-lg leading-8 text-slate-600">
      Online satıcılar için yapay zeka araçları. Kategoriye göre filtreleyin; her araç için
      artılar, eksiler ve fiyat bir bakışta.
    </p>
  </header>

  <!-- Kategori filtresi (ilerlemeli geliştirme: JS olmadan tümü görünür) -->
  <div class="mb-8 flex flex-wrap gap-2" data-filtre-grup>
    <button class="chip chip-active" data-filtre="all">Tümü</button>
    {KATEGORILER.map((k) => <button class="chip" data-filtre={k.ad}>{k.ad}</button>)}
  </div>

  <div class="grid gap-5 sm:grid-cols-2" data-arac-liste>
    {
      tools.length > 0 ? (
        tools.map((tool) => <ToolCard tool={tool} />)
      ) : (
        <p class="text-sm text-slate-500">Henüz araç eklenmedi.</p>
      )
    }
  </div>
</BaseLayout>

<script>
  // Basit istemci tarafı kategori filtresi.
  const butonlar = document.querySelectorAll<HTMLButtonElement>('[data-filtre]');
  const kartlar = document.querySelectorAll<HTMLElement>('[data-arac-liste] [data-kategori]');

  butonlar.forEach((btn) => {
    btn.addEventListener('click', () => {
      const secili = btn.dataset.filtre;

      butonlar.forEach((b) => b.classList.remove('chip-active'));
      btn.classList.add('chip-active');

      kartlar.forEach((kart) => {
        const goster = secili === 'all' || kart.dataset.kategori === secili;
        kart.style.display = goster ? '' : 'none';
      });
    });
  });
</script>
