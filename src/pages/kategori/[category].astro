---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { KATEGORILER, kategoriBySlug } from '../../lib/categories';
import { getPostsByKategori } from '../../lib/content';

export async function getStaticPaths() {
  return KATEGORILER.map((k) => ({ params: { category: k.slug } }));
}

const { category } = Astro.params;
const kategori = kategoriBySlug(category!);

if (!kategori) {
  return Astro.redirect('/404');
}

const posts = await getPostsByKategori(kategori.ad);
---

<BaseLayout
  title={`${kategori.ad} — AI araçları yazıları`}
  description={`${kategori.ad} kategorisinde online satıcılar için yapay zeka araçları incelemeleri ve rehberleri.`}
>
  <h1 class="text-3xl font-bold text-brand">{kategori.ad}</h1>
  <p class="mt-2 text-gray-600">Bu kategorideki tüm yazılar.</p>

  <div class="mt-6 grid gap-4 sm:grid-cols-2">
    {
      posts.length > 0 ? (
        posts.map((post) => <PostCard post={post} />)
      ) : (
        <p class="text-sm text-gray-500">Bu kategoride henüz yazı yok.</p>
      )
    }
  </div>
</BaseLayout>
