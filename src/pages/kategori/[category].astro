---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { KATEGORILER, kategoriBySlug } from '../../lib/categories';
import { getPostsByKategori } from '../../lib/content';

export async function getStaticPaths() {
  return KATEGORILER.map((k) => ({ params: { category: k.slug } }));
}

const { category } = Astro.params;
const kategori = kategoriBySlug(category!);

if (!kategori) {
  return Astro.redirect('/404');
}

const posts = await getPostsByKategori(kategori.ad);
---

<BaseLayout
  title={`${kategori.ad} — AI araçları yazıları`}
  description={`${kategori.ad} kategorisinde online satıcılar için yapay zeka araçları incelemeleri ve rehberleri.`}
>
  <nav class="mb-4 flex items-center gap-1.5 text-xs text-slate-400" aria-label="Breadcrumb">
    <a class="transition hover:text-brand" href="/">Ana sayfa</a>
    <span aria-hidden="true">/</span>
    <span class="text-slate-500">{kategori.ad}</span>
  </nav>

  <header class="mb-8">
    <h1 class="font-display text-3xl font-extrabold tracking-tight text-ink sm:text-4xl">
      {kategori.ad}
    </h1>
    <p class="mt-3 text-lg text-slate-600">
      <span class="font-semibold text-brand-dark">{kategori.ad}</span> kategorisindeki tüm incelemeler
      ve rehberler.
    </p>
  </header>

  <div class="grid gap-5 sm:grid-cols-2">
    {
      posts.length > 0 ? (
        posts.map((post) => <PostCard post={post} />)
      ) : (
        <p class="text-sm text-slate-500">Bu kategoride henüz yazı yok.</p>
      )
    }
  </div>
</BaseLayout>
