---
import BaseLayout from '../layouts/BaseLayout.astro';
import { MARKA_ADI } from '../data/site';
import { VARSAYILAN_YAZAR } from '../data/authors';

const markaAdi = MARKA_ADI;
const yazar = VARSAYILAN_YAZAR;

// Yazar için Person / ProfilePage şeması (Hakkında ile birebir tutarlı tek kaynaktan).
const site = Astro.site?.href.replace(/\/$/, '') ?? '';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  mainEntity: {
    '@type': 'Person',
    name: yazar.name,
    jobTitle: yazar.rol,
    description: yazar.kisaBio,
    email: `mailto:${yazar.email}`,
    url: `${site}${yazar.hakkindaYolu}`,
    worksFor: { '@type': 'Organization', name: markaAdi, url: site || undefined },
  },
};
---

<BaseLayout
  title={`Hakkında — ${markaAdi}`}
  description="Online satıcılar için yapay zeka araçları yayınımız hakkında ve yazar kadromuz."
  jsonLd={jsonLd}
>
  <h1 class="font-display text-3xl font-extrabold tracking-tight text-ink sm:text-4xl">Hakkında</h1>

  <div class="icerik mt-6 max-w-2xl">
    <p>
      {markaAdi}, online satıcıların (Shopify, Etsy, Amazon, Trendyol, Hepsiburada) işini
      kolaylaştıran yapay zeka araçlarını bağımsız ve özgün bir bakışla inceler. Amacımız, gerçek
      kullanım deneyimine ve karşılaştırmaya dayalı, Türkiye pazarına özel içerik üretmektir.
    </p>

    <h2>Editöryel ilkemiz</h2>
    <p>
      Bu site bir otomatik içerik fabrikası değildir. Her yazı, yayınlanmadan önce insan onayından
      geçer. Doğrulanmamış bilgileri (fiyat, komisyon, özellik) yayımlamayız. Araçları hangi
      kriterlerle test ve puanladığımızı{' '}
      <a href="/metodoloji/">Metodoloji</a> sayfamızda şeffaf biçimde açıklıyoruz.
    </p>

    <h2>Yazar</h2>
    <div class="mt-2 flex items-center gap-3 not-prose">
      <div
        class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-brand/10 font-display text-lg font-bold text-brand-dark"
        aria-hidden="true"
      >
        {yazar.name.charAt(0)}
      </div>
      <div>
        <h3 class="text-xl font-semibold text-ink">{yazar.name}</h3>
        <p class="text-sm text-slate-500">{yazar.rol}</p>
      </div>
    </div>
    {yazar.tamBio.map((p) => <p>{p}</p>)}

    <h2>İletişim</h2>
    <p>
      Soru, öneri veya iş birliği teklifleri için:{' '}
      <a href={`mailto:${yazar.email}`}>{yazar.email}</a>
    </p>
  </div>
</BaseLayout>
