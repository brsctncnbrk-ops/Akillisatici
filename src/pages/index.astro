---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import AdSlot from '../components/AdSlot.astro';
import { KATEGORILER } from '../lib/categories';
import { getYayindaPosts } from '../lib/content';
import { MARKA_ADI } from '../data/site';

const posts = await getYayindaPosts();
const oneCikan = posts[0];
const digerleri = posts.slice(1);

const pazaryerleri = [
  { ad: 'Shopify', emoji: '🛒' },
  { ad: 'Etsy', emoji: '🎨' },
  { ad: 'Amazon', emoji: '📦' },
  { ad: 'Trendyol', emoji: '🏪' },
  { ad: 'Hepsiburada', emoji: '🛍️' },
];

// Kategori adına göre ikon ve kısa açıklama (yalnızca anasayfa görselleştirmesi için).
const kategoriDetay: Record<string, { emoji: string; aciklama: string }> = {
  'İçerik üretimi': { emoji: '✍️', aciklama: 'Ürün açıklaması & metin' },
  'Ürün görseli': { emoji: '🖼️', aciklama: 'Fotoğraf & afiş üretimi' },
  'Müşteri desteği': { emoji: '💬', aciklama: 'Chatbot & yanıt asistanı' },
  'SEO & reklam': { emoji: '📣', aciklama: 'Reklam metni & arama' },
  'Stok & operasyon': { emoji: '📦', aciklama: 'Tahmin & otomasyon' },
};
---

<BaseLayout
  title={`${MARKA_ADI} — Online satıcılar için yapay zeka araçları`}
  description="Shopify, Etsy, Amazon, Trendyol ve Hepsiburada satıcıları için yapay zeka araçları: bağımsız incelemeler ve rehberler."
>
  <!-- Hero -->
  <section class="relative -mx-4 overflow-hidden px-4 pb-16 pt-12 sm:pt-20">
    <!-- Arka plan gradyanı -->
    <div
      class="pointer-events-none absolute inset-x-0 -top-16 -z-20 h-[28rem] bg-gradient-to-br from-orange-100 via-amber-50 to-transparent"
    ></div>
    <!-- İnce nokta ızgarası (üst kısımda solar) -->
    <div
      class="bg-dot-grid pointer-events-none absolute inset-x-0 -top-16 -z-20 h-[28rem] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_30%,black,transparent)]"
    ></div>
    <!-- Dekoratif, süzülen küreler -->
    <div
      class="animate-float pointer-events-none absolute -right-20 -top-24 -z-10 h-72 w-72 rounded-full bg-brand/15 blur-3xl"
    ></div>
    <div
      class="animate-float-slow pointer-events-none absolute -left-16 top-28 -z-10 h-52 w-52 rounded-full bg-amber-300/25 blur-2xl"
    ></div>

    <div class="mx-auto max-w-3xl text-center">
      <span
        class="animate-fade-up inline-flex items-center gap-2 rounded-full border border-brand/25 bg-white/70 px-4 py-1.5 text-xs font-semibold text-brand-dark shadow-sm backdrop-blur"
      >
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-brand"></span>
        </span>
        🇹🇷 Türkiye pazarına özel · bağımsız incelemeler
      </span>

      <h1
        class="animate-fade-up mt-6 font-display text-[2.6rem] font-extrabold leading-[1.05] tracking-tight text-ink sm:text-5xl lg:text-6xl"
        style="animation-delay: 80ms"
      >
        Online satıcılar için<br />
        <span class="text-gradient-brand">yapay zeka araçları</span>
      </h1>

      <p
        class="animate-fade-up mx-auto mt-5 max-w-xl text-lg leading-8 text-slate-600"
        style="animation-delay: 160ms"
      >
        İşinizi kolaylaştıran AI araçlarının özgün incelemeleri, karşılaştırmaları ve pratik
        rehberleri — pazaryeri satıcılarına özel yorumlarla.
      </p>

      <div
        class="animate-fade-up mt-8 flex flex-wrap items-center justify-center gap-3"
        style="animation-delay: 240ms"
      >
        <a
          href="/araclar/"
          class="btn-primary group px-6 py-3 text-base shadow-glow hover:-translate-y-0.5"
        >
          AI Araçlarını keşfet
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="#yazilar" class="btn-outline bg-white/60 px-6 py-3 text-base backdrop-blur hover:-translate-y-0.5">Son yazılar</a>
      </div>

      <!-- İstatistikler — kart şeklinde -->
      <div
        class="animate-fade-up mt-12 grid grid-cols-3 gap-3 sm:gap-4"
        style="animation-delay: 320ms"
      >
        <div class="rounded-2xl border border-slate-200/70 bg-white/70 px-3 py-4 shadow-soft backdrop-blur">
          <p class="font-display text-3xl font-extrabold text-ink">{posts.length}</p>
          <p class="mt-0.5 text-xs font-medium text-slate-500">yazı</p>
        </div>
        <div class="rounded-2xl border border-slate-200/70 bg-white/70 px-3 py-4 shadow-soft backdrop-blur">
          <p class="font-display text-3xl font-extrabold text-ink">{KATEGORILER.length}</p>
          <p class="mt-0.5 text-xs font-medium text-slate-500">kategori</p>
        </div>
        <div class="flex flex-col justify-center rounded-2xl border border-brand/20 bg-gradient-to-br from-orange-50 to-amber-100/60 px-3 py-4 shadow-soft">
          <p class="font-display text-xl font-extrabold text-gradient-brand sm:text-2xl">Haftalık</p>
          <p class="mt-0.5 text-xs font-medium text-slate-500">güncelleme</p>
        </div>
      </div>

      <!-- Platform pills -->
      <div
        class="animate-fade-up mt-6 flex flex-wrap items-center justify-center gap-2"
        style="animation-delay: 400ms"
      >
        {
          pazaryerleri.map((p) => (
            <span class="inline-flex items-center gap-1.5 rounded-full bg-white/80 px-3.5 py-1.5 text-sm font-medium text-slate-700 shadow-sm ring-1 ring-slate-200 backdrop-blur transition hover:-translate-y-0.5 hover:text-brand-dark hover:ring-brand/40">
              <span>{p.emoji}</span>
              {p.ad}
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Kategoriler — keşfi kolaylaştırmak için sayfanın üst kısmında -->
  <section class="mb-12">
    <h2 class="mb-4 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-slate-500">
      <span class="h-1.5 w-1.5 rounded-full bg-brand"></span> Kategoriler
    </h2>
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
      {
        KATEGORILER.map((k) => {
          const detay = kategoriDetay[k.ad];
          return (
            <a
              href={`/kategori/${k.slug}/`}
              class="group flex flex-col items-center gap-2 rounded-2xl border border-slate-200 bg-white p-4 text-center shadow-soft transition duration-200 hover:-translate-y-1 hover:border-brand/40 hover:shadow-lg"
            >
              <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-orange-50 to-amber-100 text-2xl ring-1 ring-brand/10 transition group-hover:ring-brand/30">
                {detay?.emoji ?? '🏷️'}
              </span>
              <span class="text-sm font-semibold text-ink group-hover:text-brand">{k.ad}</span>
              {detay?.aciklama && (
                <span class="text-xs leading-snug text-slate-500">{detay.aciklama}</span>
              )}
            </a>
          );
        })
      }
    </div>
  </section>

  {
    oneCikan && (
      <section class="mb-12">
        <h2 class="mb-4 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-slate-500">
          <span class="h-1.5 w-1.5 rounded-full bg-brand" /> Öne çıkan
        </h2>
        <PostCard post={oneCikan} featured={true} />
      </section>
    )
  }

  <AdSlot slot="anasayfa" />

  <section id="yazilar" class="mb-12 scroll-mt-20">
    <h2 class="mb-4 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-slate-500">
      <span class="h-1.5 w-1.5 rounded-full bg-brand"></span> En yeni yazılar
    </h2>
    {
      digerleri.length > 0 ? (
        <div class="grid gap-5 sm:grid-cols-2">
          {digerleri.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <p class="text-sm text-slate-500">Henüz başka yazı yok.</p>
      )
    }
  </section>

  <NewsletterSignup />
</BaseLayout>
