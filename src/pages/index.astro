---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import AdSlot from '../components/AdSlot.astro';
import { KATEGORILER } from '../lib/categories';
import { getYayindaPosts } from '../lib/content';
import { MARKA_ADI } from '../data/site';

const posts = await getYayindaPosts();
const oneCikan = posts[0];
const digerleri = posts.slice(1);

const pazaryerleri = [
  { ad: 'Shopify', emoji: '🛒' },
  { ad: 'Etsy', emoji: '🎨' },
  { ad: 'Amazon', emoji: '📦' },
  { ad: 'Trendyol', emoji: '🏪' },
  { ad: 'Hepsiburada', emoji: '🛍️' },
];
---

<BaseLayout
  title={`${MARKA_ADI} — Online satıcılar için yapay zeka araçları`}
  description="Shopify, Etsy, Amazon, Trendyol ve Hepsiburada satıcıları için yapay zeka araçları: bağımsız incelemeler ve rehberler."
>
  <!-- Hero -->
  <section class="relative -mx-4 overflow-hidden px-4 pb-14 pt-10 sm:pt-16">
    <!-- Arka plan gradyanı -->
    <div
      class="pointer-events-none absolute inset-x-0 -top-10 -z-10 h-96 bg-gradient-to-br from-orange-100 via-amber-50 to-transparent"
    ></div>
    <!-- Dekoratif daire -->
    <div
      class="pointer-events-none absolute -right-20 -top-20 -z-10 h-72 w-72 rounded-full bg-brand/10 blur-3xl"
    ></div>
    <div
      class="pointer-events-none absolute -left-16 top-24 -z-10 h-48 w-48 rounded-full bg-amber-300/20 blur-2xl"
    ></div>

    <div class="mx-auto max-w-3xl text-center">
      <span
        class="inline-flex items-center gap-1.5 rounded-full border border-brand/25 bg-brand/8 px-3.5 py-1.5 text-xs font-semibold text-brand-dark"
      >
        🇹🇷 Türkiye pazarına özel · bağımsız incelemeler
      </span>

      <h1 class="mt-5 font-display text-4xl font-extrabold tracking-tight text-ink sm:text-5xl lg:text-6xl">
        Online satıcılar için<br />
        <span class="text-brand">yapay zeka araçları</span>
      </h1>

      <p class="mx-auto mt-5 max-w-xl text-lg leading-8 text-slate-600">
        İşinizi kolaylaştıran AI araçlarının özgün incelemeleri, karşılaştırmaları ve pratik
        rehberleri — pazaryeri satıcılarına özel yorumlarla.
      </p>

      <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
        <a href="/araclar/" class="btn-primary inline-flex items-center gap-2 px-6 py-3 text-base">
          AI Araçlarını keşfet
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="#yazilar" class="btn-outline px-6 py-3 text-base">Son yazılar</a>
      </div>

      <!-- İstatistikler -->
      <div class="mt-10 flex flex-wrap items-center justify-center gap-6 border-y border-slate-100 py-5">
        <div class="text-center">
          <p class="text-2xl font-bold text-ink">{posts.length}</p>
          <p class="text-xs font-medium text-slate-500">yazı</p>
        </div>
        <div class="h-8 w-px bg-slate-200 hidden sm:block"></div>
        <div class="text-center">
          <p class="text-2xl font-bold text-ink">{KATEGORILER.length}</p>
          <p class="text-xs font-medium text-slate-500">kategori</p>
        </div>
        <div class="h-8 w-px bg-slate-200 hidden sm:block"></div>
        <div class="text-center">
          <p class="text-2xl font-bold text-brand">Haftalık</p>
          <p class="text-xs font-medium text-slate-500">güncelleme</p>
        </div>
      </div>

      <!-- Platform pills -->
      <div class="mt-6 flex flex-wrap items-center justify-center gap-2">
        {
          pazaryerleri.map((p) => (
            <span class="inline-flex items-center gap-1.5 rounded-full bg-white px-3.5 py-1.5 text-sm font-medium text-slate-700 shadow-sm ring-1 ring-slate-200 transition hover:ring-brand/40">
              <span>{p.emoji}</span>
              {p.ad}
            </span>
          ))
        }
      </div>
    </div>
  </section>

  {
    oneCikan && (
      <section class="mb-12">
        <h2 class="mb-4 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-slate-500">
          <span class="h-1.5 w-1.5 rounded-full bg-brand" /> Öne çıkan
        </h2>
        <PostCard post={oneCikan} featured={true} />
      </section>
    )
  }

  <AdSlot slot="anasayfa" />

  <section id="yazilar" class="mb-12 scroll-mt-20">
    <h2 class="mb-4 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-slate-500">
      <span class="h-1.5 w-1.5 rounded-full bg-brand"></span> En yeni yazılar
    </h2>
    {
      digerleri.length > 0 ? (
        <div class="grid gap-5 sm:grid-cols-2">
          {digerleri.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <p class="text-sm text-slate-500">Henüz başka yazı yok.</p>
      )
    }
  </section>

  <section class="mb-12">
    <h2 class="mb-4 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-slate-500">
      <span class="h-1.5 w-1.5 rounded-full bg-brand"></span> Kategoriler
    </h2>
    <div class="flex flex-wrap gap-2">
      {KATEGORILER.map((k) => <a href={`/kategori/${k.slug}/`} class="chip">{k.ad}</a>)}
    </div>
  </section>

  <NewsletterSignup />
</BaseLayout>
