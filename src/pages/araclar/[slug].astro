---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolLink from '../../components/ToolLink.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import PostCard from '../../components/PostCard.astro';
import AdSlot from '../../components/AdSlot.astro';
import { slugByKategori } from '../../lib/categories';
import { getTools, getYayindaPosts } from '../../lib/content';
import { MARKA_ADI } from '../../data/site';

export async function getStaticPaths() {
  const tools = await getTools();
  return tools.map((tool) => ({
    params: { slug: tool.id },
    props: { tool },
  }));
}

interface Props {
  tool: CollectionEntry<'tools'>;
}

const { tool } = Astro.props;
const { ad, kategori, fiyat, artilar, eksiler, officialUrl, affiliateUrl, aciklama } = tool.data;

const kategoriSlug = slugByKategori(kategori);

// Bu aracı inceleyen yayında yazılar (iç link + bağlam).
const tumPosts = await getYayindaPosts();
const ilgiliYazilar = tumPosts.filter((p) => p.data.incelenenAraclar.includes(tool.id));

const site = Astro.site?.href.replace(/\/$/, '') ?? '';
const canonical = `${site}/araclar/${tool.id}/`;

// JSON-LD: Product (fiyat serbest metin/null olduğundan offer EKLENMEZ — uydurma yok) + BreadcrumbList.
const productLd = {
  '@type': 'Product',
  name: ad,
  category: kategori,
  ...(aciklama ? { description: aciklama } : {}),
  ...(officialUrl ? { url: officialUrl } : {}),
  brand: { '@type': 'Brand', name: ad },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
};

const breadcrumbLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Ana sayfa', item: `${site}/` },
    { '@type': 'ListItem', position: 2, name: 'AI Araçları', item: `${site}/araclar/` },
    { '@type': 'ListItem', position: 3, name: ad, item: canonical },
  ],
};

const jsonLd = { '@context': 'https://schema.org', '@graph': [productLd, breadcrumbLd] };

const seoBaslik = `${ad} İncelemesi — Online satıcılar için (${MARKA_ADI})`;
const seoAciklama =
  aciklama ??
  `${ad}: ${kategori} kategorisinde online satıcılar için yapay zeka aracı. Artıları, eksileri ve fiyatı bir bakışta.`;
---

<BaseLayout title={seoBaslik} description={seoAciklama} jsonLd={jsonLd}>
  <article class="mx-auto max-w-3xl">
    <nav class="mb-4 flex items-center gap-1.5 text-xs text-slate-400" aria-label="Breadcrumb">
      <a class="transition hover:text-brand" href="/">Ana sayfa</a>
      <span aria-hidden="true">/</span>
      <a class="transition hover:text-brand" href="/araclar/">AI Araçları</a>
      <span aria-hidden="true">/</span>
      <span class="text-slate-500">{ad}</span>
    </nav>

    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-2">
        {
          kategoriSlug && (
            <a
              class="inline-flex rounded-full bg-brand/10 px-3 py-1 text-xs font-semibold text-brand-dark transition hover:bg-brand/20"
              href={`/kategori/${kategoriSlug}/`}
            >
              {kategori}
            </a>
          )
        }
        {
          fiyat && (
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
              {fiyat}
            </span>
          )
        }
      </div>
      <h1 class="mt-3 font-display text-3xl font-extrabold leading-tight tracking-tight text-ink sm:text-4xl">
        {ad} incelemesi
      </h1>
      {aciklama && <p class="mt-4 text-lg leading-8 text-slate-600">{aciklama}</p>}
    </header>

    <div class="grid gap-4 sm:grid-cols-2">
      {
        artilar.length > 0 && (
          <div class="rounded-2xl border border-emerald-100 bg-emerald-50/50 p-5">
            <p class="text-sm font-semibold text-emerald-600">✓ Artılar</p>
            <ul class="mt-2 space-y-1.5 text-sm leading-6 text-slate-700">
              {artilar.map((a) => (
                <li class="flex gap-2">
                  <span class="text-emerald-500" aria-hidden="true">
                    •
                  </span>
                  {a}
                </li>
              ))}
            </ul>
          </div>
        )
      }
      {
        eksiler.length > 0 && (
          <div class="rounded-2xl border border-rose-100 bg-rose-50/50 p-5">
            <p class="text-sm font-semibold text-rose-500">✕ Eksiler</p>
            <ul class="mt-2 space-y-1.5 text-sm leading-6 text-slate-700">
              {eksiler.map((e) => (
                <li class="flex gap-2">
                  <span class="text-rose-400" aria-hidden="true">
                    •
                  </span>
                  {e}
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>

    <div class="mt-6">
      <ToolLink officialUrl={officialUrl} affiliateUrl={affiliateUrl} label={`${ad}’i incele`} />
      {affiliateUrl && <AffiliateDisclosure />}
    </div>

    <AdSlot slot="arac-alti" />
  </article>

  {
    ilgiliYazilar.length > 0 && (
      <section class="mx-auto mt-14 max-w-3xl">
        <h2 class="mb-4 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-slate-500">
          <span class="h-1.5 w-1.5 rounded-full bg-brand" /> {ad} geçen yazılar
        </h2>
        <div class="grid gap-5 sm:grid-cols-2">
          {ilgiliYazilar.map((p) => (
            <PostCard post={p} />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
