---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import AuthorAvatar from '../../components/AuthorAvatar.astro';
import { YAZARLAR, type Author } from '../../data/authors';
import { getYayindaPosts } from '../../lib/content';
import { MARKA_ADI } from '../../data/site';

export async function getStaticPaths() {
  return Object.values(YAZARLAR).map((yazar) => ({
    params: { id: yazar.id },
    props: { yazar },
  }));
}

interface Props {
  yazar: Author;
}

const { yazar } = Astro.props;

// Bu yazara ait yayında yazılar (E-E-A-T: yazarın gerçek üretimi tek yerde).
const tumPosts = await getYayindaPosts();
const yaziları = tumPosts.filter((p) => p.data.yazar === yazar.name);

const site = Astro.site?.href.replace(/\/$/, '') ?? '';

// Person / ProfilePage şeması; sosyal profiller varsa sameAs ile doğrulanabilirlik.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  mainEntity: {
    '@type': 'Person',
    name: yazar.name,
    jobTitle: yazar.rol,
    description: yazar.kisaBio,
    email: `mailto:${yazar.email}`,
    url: `${site}${yazar.hakkindaYolu}`,
    ...(yazar.foto ? { image: `${site}${yazar.foto}` } : {}),
    ...(yazar.sosyal && yazar.sosyal.length > 0
      ? { sameAs: yazar.sosyal.map((s) => s.url) }
      : {}),
    worksFor: { '@type': 'Organization', name: MARKA_ADI, url: site || undefined },
  },
};
---

<BaseLayout
  title={`${yazar.name} — Yazar · ${MARKA_ADI}`}
  description={yazar.kisaBio}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-3xl">
    <div class="flex flex-col gap-5 sm:flex-row sm:items-start">
      <AuthorAvatar name={yazar.name} foto={yazar.foto} boyut="h-20 w-20" metin="text-2xl" />
      <div>
        <h1 class="font-display text-3xl font-extrabold tracking-tight text-ink sm:text-4xl">
          {yazar.name}
        </h1>
        <p class="mt-1 text-sm font-medium text-brand-dark">{yazar.rol}</p>
        {
          yazar.sosyal && yazar.sosyal.length > 0 && (
            <ul class="mt-3 flex flex-wrap gap-3 text-sm">
              {yazar.sosyal.map((s) => (
                <li>
                  <a
                    class="font-semibold text-brand-dark underline transition hover:text-brand"
                    href={s.url}
                    target="_blank"
                    rel="me noopener"
                  >
                    {s.ad}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </div>

    <div class="icerik mt-8">
      {yazar.tamBio.map((p) => <p>{p}</p>)}
      <p>
        İletişim: <a href={`mailto:${yazar.email}`}>{yazar.email}</a>
      </p>
    </div>
  </article>

  <section class="mx-auto mt-12 max-w-3xl">
    <h2 class="mb-4 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-slate-500">
      <span class="h-1.5 w-1.5 rounded-full bg-brand"></span>
      {yazar.name} imzalı yazılar ({yaziları.length})
    </h2>
    {
      yaziları.length > 0 ? (
        <div class="grid gap-5 sm:grid-cols-2">
          {yaziları.map((p) => (
            <PostCard post={p} />
          ))}
        </div>
      ) : (
        <p class="text-sm text-slate-500">Henüz yayımlanmış yazı yok.</p>
      )
    }
  </section>
</BaseLayout>
