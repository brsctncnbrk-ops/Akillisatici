---
import { KATEGORILER } from '../lib/categories';
import { MARKA_ADI, ISLETME, IYS_KAYITLI, SOSYAL } from '../data/site';
import BrandMark from './BrandMark.astro';

const yil = new Date().getFullYear();

// Kurumsal kimlik satırları — yalnızca dolu olanlar gösterilir (uydurma yok).
const kurumsalSatirlar = [ISLETME.unvan, ISLETME.adres, ISLETME.vergi].filter(Boolean);
---

<footer class="mt-16 border-t-4 border-brand bg-ink text-slate-300">
  <div class="mx-auto grid max-w-5xl gap-10 px-4 py-12 sm:grid-cols-2 lg:grid-cols-4">
    <div class="sm:col-span-2 lg:col-span-2">
      <a href="/" class="flex items-center gap-2 text-white">
        <BrandMark class="h-7 w-7 text-brand" />
        <span class="font-display text-lg font-extrabold tracking-tight">{MARKA_ADI}</span>
      </a>
      <p class="mt-3 max-w-sm text-sm leading-6 text-slate-400">
        Online satıcılar (Shopify, Etsy, Amazon, Trendyol, Hepsiburada) için yapay zeka araçlarının
        bağımsız incelemeleri, karşılaştırmaları ve pratik rehberleri.
      </p>

      {
        SOSYAL.length > 0 && (
          <ul class="mt-4 flex flex-wrap gap-3 text-sm">
            {SOSYAL.map((s) => (
              <li>
                <a
                  class="text-slate-400 transition hover:text-brand"
                  href={s.url}
                  target="_blank"
                  rel="me noopener"
                >
                  {s.ad}
                </a>
              </li>
            ))}
          </ul>
        )
      }

      {
        kurumsalSatirlar.length > 0 && (
          <address class="mt-4 text-xs not-italic leading-5 text-slate-500">
            {kurumsalSatirlar.map((satir) => (
              <span class="block">{satir}</span>
            ))}
          </address>
        )
      }

      {
        IYS_KAYITLI && (
          <p class="mt-3 text-xs leading-5 text-slate-500">
            Ticari ileti gönderimlerimiz, 6563 sayılı kanun kapsamında İleti Yönetim Sistemi'ne
            (İYS) kayıtlıdır.
          </p>
        )
      }
    </div>

    <div>
      <h2 class="font-display text-sm font-semibold uppercase tracking-wide text-white">
        Kategoriler
      </h2>
      <ul class="mt-3 space-y-2 text-sm">
        {
          KATEGORILER.map((k) => (
            <li>
              <a class="text-slate-400 transition hover:text-brand" href={`/kategori/${k.slug}/`}>
                {k.ad}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h2 class="font-display text-sm font-semibold uppercase tracking-wide text-white">Kurumsal</h2>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a class="text-slate-400 transition hover:text-brand" href="/araclar/">AI Araçları</a></li>
        <li>
          <a class="text-slate-400 transition hover:text-brand" href="/kaynaklar/">Ücretsiz Kaynaklar</a>
        </li>
        <li><a class="text-slate-400 transition hover:text-brand" href="/hakkinda/">Hakkında</a></li>
        <li>
          <a class="text-slate-400 transition hover:text-brand" href="/metodoloji/">Metodoloji</a>
        </li>
        <li><a class="text-slate-400 transition hover:text-brand" href="/gizlilik/">Gizlilik</a></li>
        <li>
          <a class="text-slate-400 transition hover:text-brand" href="/cerez-politikasi/"
            >Çerez Politikası</a
          >
        </li>
        <li>
          <a class="text-slate-400 transition hover:text-brand" href="/kullanim-sartlari/"
            >Kullanım Şartları</a
          >
        </li>
        <li>
          <a class="text-slate-400 transition hover:text-brand" href="/affiliate-aciklama/"
            >Affiliate Açıklaması</a
          >
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto max-w-5xl px-4 py-5 text-xs text-slate-500">
      © {yil} {MARKA_ADI}. Tüm hakları saklıdır.
    </div>
  </div>
</footer>
