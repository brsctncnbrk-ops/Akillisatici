---
// Reklam yerleşimi.
// Reklamlar yalnızca PUBLIC_ADS_ENABLED='true' iken render edilir (ör. AdSense onayı sonrası).
// Flag kapalıyken hiçbir şey (metin dahil) gösterilmez.
interface Props {
  slot?: string;
}
const { slot = 'genel' } = Astro.props;
const adsEnabled = import.meta.env.PUBLIC_ADS_ENABLED === 'true';
---

{
  adsEnabled && (
    <div class="my-6" data-ad-slot={slot}>
      {/* Reklam script'i (ör. AdSense ins etiketi) onay sonrası buraya yerleştirilir. */}
    </div>
  )
}
