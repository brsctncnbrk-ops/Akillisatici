---
// Sosyal paylaşım butonları — her okuyucuyu potansiyel dağıtıcıya çevirir ("tohumlama").
// Sunucuda statik üretilir; yalnızca "linki kopyala" için küçük bir inline script var.
// Türkiye kitlesi için WhatsApp ilk sırada; Pinterest görselli paylaşım için `image` alır.
interface Props {
  url: string; // kanonik yazı URL'i (tam, https ile)
  title: string; // paylaşım metninde kullanılacak başlık
  image?: string; // Pinterest pini için görsel (tam URL); yoksa Pinterest gizlenir
}

const { url, title, image } = Astro.props;

const u = encodeURIComponent(url);
const t = encodeURIComponent(title);
// WhatsApp/X gibi metin temelli kanallarda başlık + link birlikte paylaşılır.
const tu = encodeURIComponent(`${title} ${url}`);

const links = [
  {
    ad: 'WhatsApp',
    href: `https://api.whatsapp.com/send?text=${tu}`,
    renk: 'hover:bg-[#25D366] hover:text-white hover:border-[#25D366]',
    // WhatsApp glifi
    path: 'M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm5.8 14.06c-.24.68-1.42 1.32-1.96 1.36-.5.05-1.13.2-3.62-.78-3.04-1.2-4.96-4.3-5.11-4.5-.15-.2-1.22-1.62-1.22-3.09 0-1.47.77-2.19 1.04-2.49.27-.3.59-.37.79-.37l.57.01c.18.01.43-.07.67.51.24.6.83 2.07.9 2.22.07.15.12.32.02.52-.1.2-.15.32-.3.5-.15.17-.32.39-.45.52-.15.15-.3.31-.13.61.17.3.76 1.25 1.63 2.03 1.12 1 2.07 1.31 2.37 1.46.3.15.47.12.65-.07.18-.2.75-.87.95-1.17.2-.3.4-.25.67-.15.27.1 1.72.81 2.01.96.3.15.49.22.56.35.07.12.07.72-.17 1.4Z',
  },
  {
    ad: 'X',
    href: `https://twitter.com/intent/tweet?url=${u}&text=${t}`,
    renk: 'hover:bg-black hover:text-white hover:border-black',
    path: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z',
  },
  {
    ad: 'Facebook',
    href: `https://www.facebook.com/sharer/sharer.php?u=${u}`,
    renk: 'hover:bg-[#1877F2] hover:text-white hover:border-[#1877F2]',
    path: 'M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 6.02 4.39 11.01 10.13 11.92v-8.43H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.68.24 2.68.24v2.97h-1.51c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.49h-2.8v8.43C19.61 23.08 24 18.09 24 12.07Z',
  },
  {
    ad: 'LinkedIn',
    href: `https://www.linkedin.com/sharing/share-offsite/?url=${u}`,
    renk: 'hover:bg-[#0A66C2] hover:text-white hover:border-[#0A66C2]',
    path: 'M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.13 2.07 2.07 0 0 1 0 4.13ZM7.12 20.45H3.55V9h3.57v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z',
  },
];
---

<div
  class="mt-12 flex flex-wrap items-center gap-2 border-t border-slate-100 pt-6"
  data-share
  data-url={url}
>
  <span class="mr-1 text-sm font-semibold text-slate-700">Paylaş:</span>

  {
    image && (
      <a
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 text-slate-600 transition hover:bg-[#E60023] hover:text-white hover:border-[#E60023]"
        href={`https://pinterest.com/pin/create/button/?url=${u}&media=${encodeURIComponent(image)}&description=${t}`}
        target="_blank"
        rel="noopener nofollow"
        aria-label="Pinterest'te paylaş"
        title="Pinterest'te paylaş"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.08 3.16 9.42 7.62 11.17-.11-.95-.2-2.4.04-3.44.22-.93 1.4-5.94 1.4-5.94s-.36-.72-.36-1.78c0-1.66.97-2.9 2.17-2.9 1.02 0 1.51.77 1.51 1.69 0 1.03-.65 2.57-.99 4-.28 1.19.6 2.16 1.77 2.16 2.13 0 3.76-2.24 3.76-5.48 0-2.86-2.06-4.86-5-4.86-3.41 0-5.41 2.56-5.41 5.2 0 1.03.4 2.13.89 2.73.1.12.11.22.08.34l-.33 1.36c-.05.22-.17.27-.4.16-1.5-.7-2.44-2.89-2.44-4.65 0-3.78 2.75-7.26 7.92-7.26 4.16 0 7.39 2.96 7.39 6.92 0 4.13-2.6 7.45-6.22 7.45-1.21 0-2.35-.63-2.74-1.38l-.75 2.84c-.27 1.04-1 2.35-1.49 3.15 1.12.35 2.31.53 3.54.53 6.63 0 12-5.37 12-12S18.63 0 12 0Z" />
        </svg>
      </a>
    )
  }

  {
    links.map((l) => (
      <a
        class={`inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 text-slate-600 transition ${l.renk}`}
        href={l.href}
        target="_blank"
        rel="noopener nofollow"
        aria-label={`${l.ad}'te paylaş`}
        title={`${l.ad}'te paylaş`}
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d={l.path} />
        </svg>
      </a>
    ))
  }

  <button
    type="button"
    data-copy
    class="inline-flex h-10 items-center gap-1.5 rounded-full border border-slate-200 px-3 text-sm font-medium text-slate-600 transition hover:border-brand hover:text-brand-dark"
    aria-label="Bağlantıyı kopyala"
  >
    <svg
      class="h-4 w-4"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M13.19 8.69a4.5 4.5 0 0 1 0 6.36l-3 3a4.5 4.5 0 0 1-6.36-6.36l1.5-1.5m9.94 1.12 1.5-1.5a4.5 4.5 0 0 0-6.36-6.36l-3 3a4.5 4.5 0 0 0 0 6.36"
      ></path>
    </svg>
    <span data-copy-label>Linki kopyala</span>
  </button>
</div>

<script>
  // "Linki kopyala": panoya yazar ve buton etiketini kısa süreliğine "Kopyalandı" yapar.
  document.querySelectorAll('[data-share]').forEach((box) => {
    const url = (box as HTMLElement).dataset.url ?? location.href;
    const btn = box.querySelector('[data-copy]') as HTMLButtonElement | null;
    const label = box.querySelector('[data-copy-label]') as HTMLElement | null;
    if (!btn || !label) return;

    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(url);
        const eski = label.textContent;
        label.textContent = 'Kopyalandı ✓';
        setTimeout(() => {
          label.textContent = eski;
        }, 2000);
      } catch {
        // Pano API'si engelliyse kullanıcıyı bilgilendir (nadiren; eski tarayıcı/izin).
        label.textContent = 'Kopyalanamadı';
      }
    });
  });
</script>
