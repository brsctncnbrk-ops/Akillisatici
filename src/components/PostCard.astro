---
import type { CollectionEntry } from 'astro:content';
import { slugByKategori } from '../lib/categories';
import PostCover from './PostCover.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const kategoriSlug = slugByKategori(post.data.kategori);
---

<article class="card group flex flex-col overflow-hidden">
  <a href={`/posts/${post.id}/`} aria-hidden="true" tabindex="-1" class="block">
    <PostCover kategori={post.data.kategori} class={featured ? 'aspect-[16/7]' : 'aspect-[16/9]'} />
  </a>

  <div class={`flex flex-1 flex-col p-6 ${featured ? 'sm:p-8' : ''}`}>
  <div class="flex flex-wrap items-center gap-2 text-xs">
    {
      kategoriSlug && (
        <a
          class="inline-flex rounded-full bg-brand/10 px-2.5 py-1 font-semibold text-brand-dark transition hover:bg-brand/20"
          href={`/kategori/${kategoriSlug}/`}
        >
          {post.data.kategori}
        </a>
      )
    }
    <time class="text-slate-400" datetime={post.data.tarih.toISOString()}>
      {post.data.tarih.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' })}
    </time>
  </div>

  <a href={`/posts/${post.id}/`} class="mt-3 block">
    <h3
      class={`font-bold tracking-tight text-ink transition group-hover:text-brand-dark ${featured ? 'text-2xl' : 'text-lg'}`}
    >
      {post.data.baslik}
    </h3>
    <p class={`mt-2 text-slate-600 ${featured ? 'text-base' : 'text-sm'} line-clamp-3`}>
      {post.data.ozet}
    </p>
  </a>

    <a
      href={`/posts/${post.id}/`}
      class="mt-auto pt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-dark transition group-hover:gap-2"
      aria-label={`${post.data.baslik} yazısını oku`}
    >
      Devamını oku <span aria-hidden="true">→</span>
    </a>
  </div>
</article>
