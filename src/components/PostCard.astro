---
import type { CollectionEntry } from 'astro:content';
import { slugByKategori } from '../lib/categories';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const kategoriSlug = slugByKategori(post.data.kategori);
---

<article class="rounded-lg border border-gray-200 p-5 transition hover:shadow-md">
  <a href={`/posts/${post.id}/`} class="block">
    <h3 class="text-lg font-semibold text-brand">{post.data.baslik}</h3>
    <p class="mt-2 text-sm text-gray-600">{post.data.ozet}</p>
  </a>
  <div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-gray-500">
    {
      kategoriSlug && (
        <a class="text-brand-accent" href={`/kategori/${kategoriSlug}/`}>
          {post.data.kategori}
        </a>
      )
    }
    <span>·</span>
    <time datetime={post.data.tarih.toISOString()}>
      {post.data.tarih.toLocaleDateString('tr-TR')}
    </time>
  </div>
</article>
