---
import type { CollectionEntry } from 'astro:content';
import ToolLink from './ToolLink.astro';

interface Props {
  tool: CollectionEntry<'tools'>;
}

const { tool } = Astro.props;
const { ad, kategori, fiyat, artilar, eksiler, officialUrl, affiliateUrl, aciklama } = tool.data;
---

<article class="card flex flex-col p-6" data-kategori={kategori}>
  <div class="flex items-start justify-between gap-3">
    <div>
      <h3 class="text-xl font-bold tracking-tight text-ink">{ad}</h3>
      <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-brand-dark">{kategori}</p>
    </div>
    {
      fiyat && (
        <span class="shrink-0 rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
          {fiyat}
        </span>
      )
    }
  </div>

  {aciklama && <p class="mt-3 text-sm leading-6 text-slate-600">{aciklama}</p>}

  <div class="mt-4 grid gap-3 sm:grid-cols-2">
    {
      artilar.length > 0 && (
        <div>
          <p class="text-xs font-semibold text-emerald-600">✓ Artılar</p>
          <ul class="mt-1.5 space-y-1 text-sm text-slate-600">
            {artilar.map((a) => (
              <li class="flex gap-1.5">
                <span class="text-emerald-500" aria-hidden="true">
                  •
                </span>
                {a}
              </li>
            ))}
          </ul>
        </div>
      )
    }
    {
      eksiler.length > 0 && (
        <div>
          <p class="text-xs font-semibold text-rose-500">✕ Eksiler</p>
          <ul class="mt-1.5 space-y-1 text-sm text-slate-600">
            {eksiler.map((e) => (
              <li class="flex gap-1.5">
                <span class="text-rose-400" aria-hidden="true">
                  •
                </span>
                {e}
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </div>

  <div class="mt-5 border-t border-slate-100 pt-4">
    <ToolLink officialUrl={officialUrl} affiliateUrl={affiliateUrl} label={`${ad}’i incele`} />
  </div>
</article>
