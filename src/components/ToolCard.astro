---
import type { CollectionEntry } from 'astro:content';

interface Props {
  tool: CollectionEntry<'tools'>;
}

const { tool } = Astro.props;
const { ad, kategori, fiyat, artilar, eksiler, aciklama, puan } = tool.data;
const detayYolu = `/araclar/${tool.id}/`;
const tamYildiz = puan != null ? Math.round(puan) : 0;
---

<article class="card flex flex-col p-6" data-kategori={kategori}>
  <div class="flex items-start justify-between gap-3">
    <div>
      <h3 class="text-xl font-bold tracking-tight text-ink">
        <a class="transition hover:text-brand-dark" href={detayYolu}>{ad}</a>
      </h3>
      <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-brand-dark">{kategori}</p>
      {
        puan != null && (
          <p class="mt-1 flex items-center gap-1.5 text-sm" aria-label={`5 üzerinden ${puan}`}>
            <span class="text-amber-400" aria-hidden="true">
              {'★'.repeat(tamYildiz)}
              {'☆'.repeat(5 - tamYildiz)}
            </span>
            <span class="text-xs font-semibold text-slate-600">{puan.toFixed(1)}</span>
          </p>
        )
      }
    </div>
    {
      fiyat && (
        <span class="shrink-0 rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">
          {fiyat}
        </span>
      )
    }
  </div>

  {aciklama && <p class="mt-3 text-sm leading-6 text-slate-600">{aciklama}</p>}

  <div class="mt-4 grid gap-3 sm:grid-cols-2">
    {
      artilar.length > 0 && (
        <div>
          <p class="text-xs font-semibold text-emerald-600">✓ Artılar</p>
          <ul class="mt-1.5 space-y-1 text-sm text-slate-600">
            {artilar.map((a) => (
              <li class="flex gap-1.5">
                <span class="text-emerald-500" aria-hidden="true">
                  •
                </span>
                {a}
              </li>
            ))}
          </ul>
        </div>
      )
    }
    {
      eksiler.length > 0 && (
        <div>
          <p class="text-xs font-semibold text-rose-500">✕ Eksiler</p>
          <ul class="mt-1.5 space-y-1 text-sm text-slate-600">
            {eksiler.map((e) => (
              <li class="flex gap-1.5">
                <span class="text-rose-400" aria-hidden="true">
                  •
                </span>
                {e}
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </div>

  <div class="mt-5 border-t border-slate-100 pt-4">
    <a href={detayYolu} class="btn-primary w-full">
      {ad}’i incele
      <span aria-hidden="true">→</span>
    </a>
  </div>
</article>
