---
import { resolveAffiliate, hasAffiliate, AFFILIATE_REL } from '../lib/affiliate';

interface Props {
  toolKey: string;
  label: string;
}

const { toolKey, label } = Astro.props;
const entry = resolveAffiliate(toolKey);
const usable = hasAffiliate(toolKey);
// Güvenlik: yeni sekmede açılan dış linklerde noopener/noreferrer eklenir.
const rel = `${AFFILIATE_REL} noopener noreferrer`;
---

{
  usable && entry ? (
    <a
      href={entry.url}
      rel={rel}
      target="_blank"
      class="inline-flex items-center gap-1 rounded-md bg-brand-accent px-3 py-1.5 text-sm font-medium text-white hover:opacity-90"
    >
      {label}
      <span class="text-[10px] uppercase opacity-80">reklam</span>
    </a>
  ) : (
    <span class="text-xs text-gray-400">{label} (affiliate linki: TBD)</span>
  )
}
